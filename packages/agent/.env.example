# kubebolt-agent — environment variables.
#
# The agent is a DaemonSet pod, not a process you run from a dotenv
# file. These values belong in the Pod spec's `env:` block
# (see deploy/agent/kubebolt-agent-dev.yaml for a working example),
# NOT in the root `.env` that docker-compose loads for the backend.
#
# This file exists so operators have a single place to discover every
# knob the agent supports, plus the default each one takes when left
# unset. Copy the lines you need into your own manifest; leave the
# rest off and the agent will pick reasonable defaults.

# ─── Core ─────────────────────────────────────────────────────
# Backend gRPC address. Point this at whatever resolves to the
# KubeBolt API's :9090 inside your cluster:
#   - Docker Desktop + backend on the host: host.docker.internal:9090
#   - In-cluster backend (Service "kubebolt" in ns "kubebolt"):
#       kubebolt.kubebolt.svc.cluster.local:9090
KUBEBOLT_BACKEND_URL=localhost:9090

# The kubelet the agent talks to for /stats/summary + /pods + the
# cAdvisor fallback. Downward-API bind them to the pod's own node:
#   KUBEBOLT_AGENT_NODE_NAME -> spec.nodeName
#   KUBEBOLT_AGENT_NODE_IP   -> status.hostIP
KUBEBOLT_AGENT_NODE_NAME=
KUBEBOLT_AGENT_NODE_IP=

# Log verbosity. debug is very chatty (per-sample lines) — prefer info
# in production.
KUBEBOLT_AGENT_LOG_LEVEL=info

# ─── Backend authentication (Sprint A) ───────────────────────
# How the agent identifies itself to the backend. Empty (default)
# means no credentials — only works when the backend runs with
# KUBEBOLT_AGENT_AUTH_MODE=disabled (the migration default).
#
# When KUBEBOLT_AGENT_AUTH_MODE is set, KUBEBOLT_AGENT_TOKEN_FILE
# must point at a file readable at startup. Half-set combinations
# (mode without file, or vice-versa) abort the agent at boot.
#
#   tokenreview     projected K8s ServiceAccount token. Backend
#                   validates via the apiserver TokenReview API.
#                   Requires backend in the same cluster.
#   ingest-token    long-lived bearer token issued by the backend
#                   admin UI. Required for SaaS / cross-cluster.
#KUBEBOLT_AGENT_AUTH_MODE=ingest-token
#KUBEBOLT_AGENT_TOKEN_FILE=/var/run/secrets/kubebolt/token

# ─── Transport security to backend ───────────────────────────
# Independent from auth.mode. With TLS off + auth on the bearer
# travels in plaintext (the agent logs a WARN). Acceptable for dev
# / trusted internal networks; production should set TLS_ENABLED=true.
#
# ENTERPRISE-CANDIDATE: plain TLS (CA only) stays OSS; the mTLS
# client cert path (CERT_FILE + KEY_FILE) is a candidate to move
# behind a license gate when the SaaS hospedado launches.
#KUBEBOLT_AGENT_TLS_ENABLED=true
#KUBEBOLT_AGENT_TLS_CA_FILE=/etc/kubebolt-tls/ca.crt
#KUBEBOLT_AGENT_TLS_CERT_FILE=/etc/kubebolt-tls/tls.crt
#KUBEBOLT_AGENT_TLS_KEY_FILE=/etc/kubebolt-tls/tls.key
#KUBEBOLT_AGENT_TLS_SERVER_NAME=

# ─── Cluster identity ────────────────────────────────────────
# Every sample the agent emits carries a `cluster_id` label so that
# two agents in two clusters can't accidentally sum into one series
# in VictoriaMetrics. The agent auto-discovers this by reading the
# kube-system namespace UID at startup — unique per cluster,
# immutable, no configuration needed.
#
# Only set KUBEBOLT_AGENT_CLUSTER_ID when migrating a legacy install
# that has historical series under a different ID you want to keep.
KUBEBOLT_AGENT_CLUSTER_ID=

# Optional human-readable label emitted alongside cluster_id.
# Example: "prod-eks-us-east-1". The UI itself prefers the kubeconfig
# context name the backend already knows about, so this is mostly
# for operators querying VictoriaMetrics directly.
KUBEBOLT_AGENT_CLUSTER_NAME=

# ─── Downward-API identity (required for flow collector) ─────
# The Hubble flow-collector uses the Pod name as its leader-election
# identity and reads POD_NAMESPACE to locate the Lease. Set both via
# the downward API in your DaemonSet spec — plain env values won't
# work because each pod needs its own identity.
#   POD_NAME      -> metadata.name
#   POD_NAMESPACE -> metadata.namespace

# ─── Hubble flow collector ───────────────────────────────────
# Streams network flows from Cilium's Hubble Relay. Only one agent
# pod in the cluster is elected leader at a time (via a Lease) so the
# relay doesn't get N-times-counted.
#
# Kill-switch: set to false to turn flow collection off entirely
# without redeploying. Accepts 1/0, true/false, yes/no (case-
# insensitive). Default is on — the collector silently no-ops when
# Cilium isn't installed, so leaving this at default is safe.
KUBEBOLT_HUBBLE_ENABLED=true

# Relay address override. Default targets a stock `cilium hubble
# enable` install. Change it for non-standard ports, namespaces, or
# mesh configurations.
#KUBEBOLT_HUBBLE_RELAY_ADDR=hubble-relay.kube-system.svc.cluster.local:80

# TLS / mTLS to the relay. Presence of CA_FILE enables TLS; adding
# CERT_FILE + KEY_FILE turns on mTLS. Mount the cert material into
# the pod via a Secret volume (see kubebolt-agent-dev.yaml for the
# commented template). Without any of these set the client falls
# back to insecure plaintext, which is fine inside the pod network.
#KUBEBOLT_HUBBLE_RELAY_CA_FILE=/etc/hubble-tls/ca.crt
#KUBEBOLT_HUBBLE_RELAY_CERT_FILE=/etc/hubble-tls/tls.crt
#KUBEBOLT_HUBBLE_RELAY_KEY_FILE=/etc/hubble-tls/tls.key
#KUBEBOLT_HUBBLE_RELAY_SERVER_NAME=*.hubble-relay.cilium.io
