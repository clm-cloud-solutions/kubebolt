# KubeBolt local development environment variables.
# Copy this file to .env and fill in values to enable optional features.
# The .env file is auto-loaded by `make dev` (and is gitignored).
#
# ═══════════════════════════════════════════════════════════════════
#  HOW TO READ THIS FILE (spec #09 V2 reorganization, 2026-05-24)
# ═══════════════════════════════════════════════════════════════════
#
# Variables are grouped into TWO TIERS:
#
#   [BOOT-TIME — cannot move to UI]
#     Read before BoltDB / the HTTP router / the JWT service can
#     answer a request. There is no UI before these are resolved,
#     so they MUST be set in env (or rely on built-in defaults).
#     Subsections explain why each category can't be runtime.
#
#   [Runtime-configurable — editable in the admin UI]
#     The env value is the BOOT FALLBACK. The admin Settings UI
#     persists overrides to BoltDB; subsequent reads return the
#     BoltDB value. Useful as env baselines for GitOps /
#     config-as-code workflows that want to seed an install. You
#     can leave every var in this tier empty and configure
#     end-to-end from the UI after first login.
#
# To inspect what's wired in vs UI-overridden at runtime, log in as
# admin → Settings → "Boot snapshot" (top-right button).
#
# ═══════════════════════════════════════════════════════════════════
#  TIER 1: BOOT-TIME (cannot move to UI)
# ═══════════════════════════════════════════════════════════════════

# ─── [BOOT-TIME] Process bootstrap ─────────────────────────────
# Read before the logger / BoltDB are initialized. There is no
# observer to surface UI changes for these because the observer
# doesn't exist yet at this stage.
# LOG_LEVEL: debug | info (default) | warn | error
# LOG_FORMAT: text (default) | json — use json for machine-parseable logs
# LOG_DIR: when set, logs are tee'd to $DIR/kubebolt.log (appended).
#          Pairs well with LOG_FORMAT=json for offline parsing.
# AI_DEBUG (legacy): "1" forces LOG_LEVEL=debug; prefer LOG_LEVEL directly.

KUBEBOLT_LOG_LEVEL=info
KUBEBOLT_LOG_FORMAT=text
KUBEBOLT_LOG_DIR=

# ─── [BOOT-TIME] Auth bootstrap ───────────────────────────────
# JWT signing key, admin seeding, recovery escape hatches.
# Changing the signing key from UI would invalidate every session
# AND every encrypted-at-rest settings secret (Copilot API key,
# webhook URLs); seeding values are first-boot-only by definition.
# Recovery vars exist to recover when the UI is unreachable, so
# they can't depend on the UI.

KUBEBOLT_AUTH_ENABLED=true
KUBEBOLT_ADMIN_PASSWORD=
KUBEBOLT_JWT_SECRET=

# Initial admin password seeded into the BoltDB user store on first
# boot. Distinct from KUBEBOLT_ADMIN_PASSWORD — that one's for runtime
# auth checks; this one only triggers when no users exist yet.
KUBEBOLT_AUTH_INITIAL_ADMIN_PASSWORD=

# Reset the admin user's password on next start. Useful for recovery
# when the UI is unreachable. Unset after the next start so the
# value doesn't sit in .env.
KUBEBOLT_RESET_ADMIN_PASSWORD=

# Path where the backend persists its BoltDB (users, tokens, agent
# registry, tenant store, copilot sessions). Default /data — make
# sure the directory exists and is writable by the process user.
# Can't be UI-editable because we'd have to read settings to know
# where to read settings from.
KUBEBOLT_DATA_DIR=/data

# ═══════════════════════════════════════════════════════════════════
#  TIER 2: RUNTIME-CONFIGURABLE (editable in admin Settings UI)
# ═══════════════════════════════════════════════════════════════════
#
# Every var below is documented here as the boot fallback. The
# admin UI's Settings tabs persist overrides into BoltDB and those
# win on every subsequent read. You can leave the entire section
# empty and configure end-to-end from the UI after first login.
#
# JWT TTLs are technically a sub-domain of Auth and surface in the
# Auth tab. They're runtime-editable but require a restart to apply
# because the JWT service is wired at boot — the UI flags
# "pendingRestart" when changed.

# ─── [Runtime] Auth TTLs → Settings → Auth ─────────────────────
# JWT access + refresh token lifetimes. Restart required after
# change for the new TTLs to take effect on the running JWT service.

# JWT access token lifetime (Go duration: 15m, 1h). Default 15m.
# Refresh tokens live in an httpOnly cookie + a server-side hash.
KUBEBOLT_JWT_EXPIRY=15m
KUBEBOLT_JWT_REFRESH_EXPIRY=720h

# ─── [Runtime] AI Copilot → Settings → AI Copilot ──────────────
# The copilot is disabled when KUBEBOLT_AI_API_KEY is empty.
# KubeBolt itself works fully without the copilot.

KUBEBOLT_AI_PROVIDER=anthropic
KUBEBOLT_AI_API_KEY=
KUBEBOLT_AI_MODEL=
KUBEBOLT_AI_BASE_URL=
KUBEBOLT_AI_MAX_TOKENS=4096

# Optional fallback model — used when the primary fails (rate limits, 5xx).
# Can be a different provider or just a cheaper model from the same provider.
KUBEBOLT_AI_FALLBACK_PROVIDER=
KUBEBOLT_AI_FALLBACK_API_KEY=
KUBEBOLT_AI_FALLBACK_MODEL=
KUBEBOLT_AI_FALLBACK_BASE_URL=

# Conversation memory — keeps long sessions usable without burning context.
# Auto-compact folds older turns into a summary (via a cheap-tier LLM call)
# when the conversation approaches the budget. A manual "new session with
# summary" button in the UI triggers the same flow on demand.
#   AUTO_COMPACT              master switch for auto-compaction.
#   SESSION_BUDGET_TOKENS     total context ceiling (100%). 0/empty = auto
#                             from the configured model (e.g. 1000000 for
#                             Claude Sonnet 4.6, 400000 for GPT-5).
#   AUTO_COMPACT_THRESHOLD    fraction of SESSION_BUDGET_TOKENS at which
#                             auto-compact triggers (0.80 = 80%). With a
#                             1M budget and 0.80 threshold, compaction
#                             fires at 800K tokens.
#   COMPACT_MODEL             override the cheap model used to summarize.
#                             Empty = auto (anthropic → claude-haiku-4-5,
#                             openai → gpt-4o-mini).
#   COMPACT_PRESERVE_TURNS    turns kept intact after compaction.
KUBEBOLT_AI_AUTO_COMPACT=true
KUBEBOLT_AI_SESSION_BUDGET_TOKENS=
KUBEBOLT_AI_AUTO_COMPACT_THRESHOLD=0.80
KUBEBOLT_AI_COMPACT_MODEL=
KUBEBOLT_AI_COMPACT_PRESERVE_TURNS=3

# Kobi conversation history — persisted per user so the operator can refresh
# the browser / re-login and resume a past conversation. Requires auth/BoltDB
# (the same gate as the rest of the admin surface); chat stays ephemeral when
# disabled.
#   RETENTION_HORIZON   drop conversations not touched within this Go duration
#                       (e.g. 2160h = 90d). Default 90d.
#   MAX_PER_USER        cap on stored conversations per user; the oldest drop
#                       out once exceeded. Default 200.
KUBEBOLT_COPILOT_CONVERSATION_RETENTION_HORIZON=2160h
KUBEBOLT_COPILOT_CONVERSATION_MAX_PER_USER=200

# Render persistent collapsible cards in the chat panel for each tool call
# (tool name + status + click-to-expand result). Default true. Set to false
# to keep only the final assistant text and a transient loading indicator.
KUBEBOLT_AI_SHOW_TOOL_CALLS=true

# Kobi action governance (Sprint 1). Master switch: when false, Kobi's
# propose_* tools are withheld and it reverts to read-only advisory (the
# 1.12 behavior). Default true (the action surface already shipped — this
# is an opt-out for compliance-conscious operators).
KUBEBOLT_AI_ACTIONS_ENABLED=true
# Destructive-ops sub-switch: when false, destructive Kobi verbs (delete,
# scale-to-0) are withheld from the LLM and rejected server-side. Has no
# effect when KUBEBOLT_AI_ACTIONS_ENABLED=false. Default true.
KUBEBOLT_AI_DESTRUCTIVE_ACTIONS_ENABLED=true
# How long the UI polls an executed action for convergence before declaring
# it stalled and asking Kobi to investigate why (Go duration; floored at 10s).
# Real case: a scale 3→4 blocked by a namespace ResourceQuota never converges —
# this bounds the wait, then auto-triggers a root-cause turn. Default 90s.
KUBEBOLT_AI_ACTION_PROGRESS_TIMEOUT=90s
# Max tool-call rounds for one Kobi turn (one model turn that calls >=1 tool =
# one round). On exhaustion Kobi runs a final tools-free turn that summarizes
# what it found instead of erroring out. Raise it for small, sequential models
# (e.g. Haiku) that call tools one at a time and need more steps for a deep RCA.
# Clamped to [2, 40]. Default 20.
KUBEBOLT_AI_MAX_ROUNDS=20

# ─── [Runtime] Notifications → Settings → Notifications ───────
# Each channel is enabled by providing its webhook URL.
# Disabled when no URLs are set. Never sends anything on its own.
# Insights at or above MIN_SEVERITY trigger notifications; same insight
# within COOLDOWN is only sent once.
# BASE_URL is optional — included as a link back to KubeBolt.

KUBEBOLT_SLACK_WEBHOOK_URL=
KUBEBOLT_DISCORD_WEBHOOK_URL=
# Master kill switch for all notifications. Set to false during maintenance
# windows or deploys to silence every channel without un-configuring them.
KUBEBOLT_NOTIFICATIONS_ENABLED=true
KUBEBOLT_NOTIFICATIONS_MIN_SEVERITY=warning
KUBEBOLT_NOTIFICATIONS_COOLDOWN=1h
KUBEBOLT_NOTIFICATIONS_BASE_URL=
# Also send a notification when an insight transitions to resolved.
KUBEBOLT_NOTIFICATIONS_INCLUDE_RESOLVED=false

# ─── [Runtime] Email (SMTP) → Settings → Notifications ────────
# Enabled when HOST + FROM + TO are all set.
# Port 587 uses STARTTLS (most providers); port 465 uses implicit TLS.
# TO accepts multiple addresses separated by commas.
# DIGEST_MODE: "instant" (default, per insight), "hourly", "daily"

KUBEBOLT_SMTP_HOST=
KUBEBOLT_SMTP_PORT=587
KUBEBOLT_SMTP_USERNAME=
KUBEBOLT_SMTP_PASSWORD=

# FROM accepts two formats:
#   1. Plain address:        alerts@example.com
#   2. With display name:    KubeBolt Alerts <alerts@example.com>
# The display name is what recipients see as the sender in their inbox.
KUBEBOLT_SMTP_FROM=

KUBEBOLT_SMTP_TO=
KUBEBOLT_SMTP_DIGEST_MODE=instant

# ─── [Runtime] Agents & Ingest channel → Settings → Agents & Ingest ──
# Spec #09 V2 moves the agent ↔ backend communication plane
# entirely into the admin UI. Each var below documents what it
# does AS A BOOT FALLBACK; the UI is the runtime authority and
# UI changes don't need a redeploy (except the three
# RESTART-REQUIRED fields below, which are wired into the gRPC
# interceptor at boot).
#
# Controls how the backend exposes its gRPC channel for kubebolt-agent
# DaemonSet instances and how it authenticates incoming connections.
# DaemonSet-side counterparts live on the Pod spec — see the comment
# block at the bottom of this file.

# Enforcement matrix for the auth interceptor:
#   disabled    accept every connection (Sprint A migration default).
#               The agent can dial without credentials.
#   permissive  try to authenticate; on failure log a WARN and accept.
#               Useful while migrating an existing fleet onto auth.
#   enforced    reject any unauthenticated / failed connection.
# When unset or invalid, the backend logs a warning and falls back to
# disabled.
KUBEBOLT_AGENT_AUTH_MODE=disabled

# Bind address for the gRPC channel. Defaults to <host>:9090, where
# <host> is the --host flag value (typically 0.0.0.0). Override only
# when you need a non-default port or interface.
#
# NOTE: this is actually BOOT-TIME (the listener binds at startup),
# but it lives in this section because the agent docs traditionally
# pair it with KUBEBOLT_AGENT_AUTH_MODE — keeping them together
# matches the operator's mental model.
KUBEBOLT_AGENT_GRPC_ADDR=

# Audience the apiserver-issued projected SA token must carry when an
# agent uses auth.mode=tokenreview. Must match auth.tokenReview.audience
# in the kubebolt-agent helm chart values. Default if unset:
# "kubebolt-backend".
KUBEBOLT_AGENT_TOKEN_AUDIENCE=

# Transport security for the gRPC channel.
# Half-set combinations (cert without key, REQUIRE_MTLS without
# CLIENT_CA, REQUIRE_MTLS without server cert) fail loud at boot.
#
# ENTERPRISE-CANDIDATE: plain TLS (server cert only) stays OSS; the
# mTLS path (CLIENT_CA + REQUIRE_MTLS) is a candidate to move behind a
# license gate when the SaaS hospedado launches.
#
# NOTE: the three FILE paths below are BOOT-TIME (Bucket A —
# filesystem paths loaded into the TLS listener at startup; UI
# upload flow is future-spec). KUBEBOLT_AGENT_REQUIRE_MTLS is
# RUNTIME (Settings → Agents & Ingest → Require mTLS toggle).
KUBEBOLT_AGENT_TLS_CERT_FILE=
KUBEBOLT_AGENT_TLS_KEY_FILE=
KUBEBOLT_AGENT_TLS_CLIENT_CA=
KUBEBOLT_AGENT_REQUIRE_MTLS=false

# Per-tenant token-bucket rate limiter. Off by default. Empty TenantID
# (disabled / permissive-fallback synthetic identity) is always allowed.
#
# ENTERPRISE-CANDIDATE: the algorithm itself stays OSS — operators get
# a single global limit applied to every tenant. Per-tenant plan-based
# policies (free=1k rps, team=10k rps, etc.) is the candidate to move
# behind a license gate when the SaaS hospedado launches.
KUBEBOLT_AGENT_RATE_LIMIT_ENABLED=false
KUBEBOLT_AGENT_RATE_LIMIT_RPS=1000
KUBEBOLT_AGENT_RATE_LIMIT_BURST=2000

# Auto-register agent-proxy clusters (Sprint A.5). When true, every
# agent that advertises the kube-proxy capability in Hello also gets
# its cluster surfaced in the manager's listing under the synthetic
# context name `agent:<cluster_id>` — no manual cluster registration
# needed.
#
# Default false. Single-cluster self-hosted deployments leave it off:
# they already have a kubeconfig context for the only cluster and an
# auto-registered `agent:local` peer would just be confusing. Multi-
# cluster SaaS / fleet operators flip it on so newly deployed agents
# show up automatically.
#
# Without this flag the cluster stays invisible to the UI even if the
# agent is connected — until a future POST /api/v1/admin/clusters
# admin endpoint lands. The kube-proxy capability flag itself lives
# on the agent side (KUBEBOLT_AGENT_PROXY_ENABLED).
#
# Note on RBAC: when reaching a cluster via agent-proxy, every API
# call carries the AGENT's ServiceAccount token. The default agent
# RBAC (kubebolt-agent-reader) covers metrics-only — Nodes/Services/
# etc come back as "No access". To unlock the full UI through the
# proxy, grant the agent operator-tier RBAC: apply
# deploy/agent/kubebolt-agent-rbac-operator.yaml or run
# `make agent-rbac-operator`. Trade-off documented in the manifest.
KUBEBOLT_AGENT_AUTOREGISTER_CLUSTERS=false

# Persistence horizon for the agent registry (Sprint A.5+). Records
# whose `disconnectedAt` is older than this duration are pruned by an
# hourly ticker — keeps the BoltDB clean of agents that connected
# once and never came back. Records for currently-connected agents
# (DisconnectedAt zero) never expire. Go duration: 12h, 7d, 24h.
# Default: 24h.
KUBEBOLT_AGENT_REGISTRY_PRUNE_HORIZON=24h

# Max gRPC message size on the agent channel, both directions (api <-> agent).
# The channel proxies apiserver responses that can exceed gRPC's 4 MiB default on
# large clusters — symptom: "ResourceExhausted: received message larger than max",
# which tears down the whole session (metrics included). Must match the agent's
# value (packages/agent KUBEBOLT_AGENT_MAX_MSG_BYTES). Bytes. Default: 67108864 (64 MiB).
KUBEBOLT_AGENT_MAX_MSG_BYTES=67108864

# Retention horizon for persisted insights (Sprint 0). RESOLVED insight
# records older than this are pruned by an hourly ticker; ACTIVE insights
# never expire. Controls how far back the /insights?history=true view can
# look. Go duration: 12h, 7d, 24h. Default: 7d (168h). Requires auth/BoltDB
# enabled — with no store, insights stay in-memory only.
KUBEBOLT_INSIGHTS_RETENTION_HORIZON=168h

# Retention horizon for the action-audit trail (Sprint 1). Records of
# cluster mutations (UI + Kobi-proposed) older than this are pruned by an
# hourly ticker. Surfaced in the admin action-history view. Go duration.
# Default: 90d (2160h). Requires auth/BoltDB enabled.
KUBEBOLT_AUDIT_RETENTION_HORIZON=2160h

# Idle timeout for SPDY tunnels opened via agent-proxy (exec,
# portforward, file browser). When no read or write activity has
# happened on a tunnel for this duration, the backend's watchdog
# closes it — catches orphan tunnels left behind when the agent
# crashes mid-session and the apiserver-side HTTP client doesn't
# notice the upstream EOF. Set to 0 to disable the watchdog (useful
# for tests; not recommended in prod). Go duration: 30s, 5m, 1h.
# Default: 5m.
KUBEBOLT_AGENT_TUNNEL_IDLE_TIMEOUT=5m

# Agent-proxy resilience timeouts (configurable so you can WIDEN them under heavy agent
# concurrency or TIGHTEN them to fail faster). Go durations.
# Hard deadline for an agent-proxy cluster connect/cache-sync; a stuck agent fails the
# connect (cluster shown unreachable) instead of hanging. Default: 25s.
KUBEBOLT_AGENT_PROXY_CONNECT_TIMEOUT=25s
# If an agent has in-flight proxied requests but delivers no response for this long, the
# backend force-closes its channel to trigger a fresh reconnect. 0 disables. Default: 45s.
KUBEBOLT_AGENT_PROXY_STUCK_TIMEOUT=45s
# Fallback per-request timeout for non-watch agent-proxy calls when the caller sets none.
# Default: 30s.
KUBEBOLT_AGENT_PROXY_REQUEST_TIMEOUT=30s

# ─── [BOOT-TIME] Infra integration ─────────────────────────────
# Endpoints resolved at startup. Editing via UI would invalidate
# in-flight queries against the previous target — has to be env.

# Where the backend writes received samples. Defaults to a local
# VictoriaMetrics on :8428. Override when running VM as a separate
# Service or out-of-cluster.
KUBEBOLT_METRICS_STORAGE_URL=http://localhost:8428

# ─── [Runtime] Prom remote_write receiver → Settings → Agents & Ingest ──
# Gates the POST /api/v1/prom/write endpoint that vmagent (sidecar
# in kubebolt-agent v1.0+) uses to ship scraped Prom-compatible
# metrics into VictoriaMetrics. Default OFF — set to "true" to
# enable.
KUBEBOLT_REMOTE_WRITE_ENABLED=false

# Three-tier enforcement for the receiver, mirrors KUBEBOLT_AGENT_AUTH_MODE
# semantics for the gRPC channel. Same TenantsStore, same bearer-token
# infrastructure (vmagent reuses the agent's ingest-token Secret).
#
#   disabled    Authorization header IGNORED. Anyone reachable on the
#               port can POST. Sprint A migration default — keeps
#               existing dev installs working while operators
#               provision tokens.
#   permissive  Bearer optional; if present must validate, but
#               missing/bad bearers log a WARN and pass through.
#               Same fallback behavior as the gRPC channel — useful
#               while rolling tokens out to a fleet.
#   enforced    Bearer required AND validated against TenantsStore.
#               Missing/bad bearer → 401. Production posture.
#               Backend startup downgrades enforced→disabled with a
#               WARN if KUBEBOLT_AUTH_ENABLED=false (no store to
#               validate against).
KUBEBOLT_REMOTE_WRITE_AUTH_MODE=disabled

# ─── [Runtime] Prom write fleet defaults → Settings → Agents & Ingest ──
# Fleet-wide defaults applied to the rate limiter + cardinality
# enforcement on /api/v1/prom/write. Tenants without custom
# overrides in the admin API inherit these values. Override per-
# tenant via PUT /admin/tenants/:id/limits.
#
# Rate limit (token bucket per tenant):
#   SAMPLES_PER_SEC  Sustained samples/sec the tenant may ingest.
#                    10k is generous for a typical 50-pod cluster
#                    (~50 samples/sec aggregate); leaves headroom
#                    for app exporters + burst.
#   BURST_SAMPLES    Token bucket size. Covers ~10s of full
#                    scrape cycles at the steady rate.
#
# Cardinality (VM-authoritative count refreshed every 30s):
#   MAX_ACTIVE_SERIES  Active series cap. Past this → HTTP 413
#                      with Retry-After: 3600. Per-tenant slice
#                      of the global VM index budget.
#
# Any unset / non-positive value falls back to the constant in
# internal/config/limits.go with a WARN log at startup.
KUBEBOLT_PROM_WRITE_DEFAULT_SAMPLES_PER_SEC=10000
KUBEBOLT_PROM_WRITE_DEFAULT_BURST_SAMPLES=100000
KUBEBOLT_PROM_WRITE_DEFAULT_MAX_ACTIVE_SERIES=1000000

# Global series cap across all tenants. When set (>0), the receiver
# additionally rejects samples that would push total active series past
# this number, regardless of per-tenant headroom. 0 / empty = disabled
# (per-tenant caps only).
KUBEBOLT_PROM_WRITE_DEFAULT_MAX_ACTIVE_SERIES_GLOBAL=

# ─── [Runtime] General settings → Settings → General ──────────
# Regex pattern that classifies a namespace as "production". Secret
# Reveal requires Admin role in matching namespaces (Editor elsewhere).
# Default: "^(prod|production|prd)([-_].+)?$" matches `prod`, `prod-eu`,
# `production`, `prd-us-east`, etc. but NOT `prod-ops-dev`.
# UI gives a live regex preview while editing.
KUBEBOLT_PROD_NAMESPACE_PATTERN=

# Display name shown in the topbar / browser title. Empty = "KubeBolt".
# Useful when multiple installs run side-by-side for distinguishing
# which one you're looking at.
KUBEBOLT_DISPLAY_NAME=

# Default refresh interval (seconds) seeded into new users'
# RefreshContext. Per-user overrides via the DataFreshnessIndicator
# dropdown still win. Allowed: 5, 10, 15, 30, 60, 120.
KUBEBOLT_DEFAULT_REFRESH_INTERVAL_SECONDS=30

# Whether the backend periodically queries the GitHub releases API
# to surface a "new version available" chip in the UI. Set to false
# for air-gapped installs — no outbound traffic to github.com will
# occur in that case. Cache TTL is 6h backend-side, so traffic stays
# well under GitHub's 60/h unauth rate limit. Admins can also toggle
# at runtime via Settings → General (BoltDB override wins over env).
# Allowed: true, false, 1, 0. Default: true.
KUBEBOLT_UPDATE_CHECK_ENABLED=true

# How long a cold cluster connect waits (seconds) for informer caches to
# sync before failing with "cluster may be unreachable". Large clusters
# (many resource types) can need 20-30s, so the default is generous; the
# warm connector pool keeps repeat switches instant regardless. Raise it
# (e.g. 60-90) for big EKS/GKE clusters that flake on the first switch.
# Admins can also set this at runtime via Settings → General (no restart;
# BoltDB override wins over env). Range 5-600. Default: 45.
KUBEBOLT_CACHE_SYNC_TIMEOUT_SECONDS=45

# Legacy debug toggle — set to "1" to force LOG_LEVEL=debug. Prefer
# setting KUBEBOLT_LOG_LEVEL=debug directly. Kept for backwards
# compatibility with pre-1.8 installs. Slated for removal in 1.13.
KUBEBOLT_AI_DEBUG=

# ─── kubebolt-agent (DaemonSet env) ───────────────────────────
# Agent env vars live on the Pod spec, not in this file. See
# packages/agent/.env.example for the full, authoritative list and
# defaults. Quick reference:
#
#   KUBEBOLT_BACKEND_URL                where the agent ships samples to
#   KUBEBOLT_AGENT_NODE_NAME/_IP        downward-API: spec.nodeName / status.hostIP
#   KUBEBOLT_AGENT_CLUSTER_NAME         human-readable label; cluster_id is
#                                       auto-discovered from the kube-system UID
#   KUBEBOLT_TENANT_ID                  per-tenant identifier for SaaS ingest
#                                       (Phase 3 Day 4.2)
#   KUBEBOLT_HUBBLE_ENABLED             flow collector kill-switch (default true)
#   KUBEBOLT_HUBBLE_RELAY_ADDR          override default relay target
#   KUBEBOLT_HUBBLE_RELAY_CA_FILE       enables TLS (add CERT_FILE+KEY_FILE for mTLS)
#   KUBEBOLT_AGENT_DEFER_NODE_NETWORK   suppress agent's node_network_* emission
#                                       when external Prom scrapes node-exporter
#                                       (deduplication)
#   KUBEBOLT_AGENT_PROXY_ENABLED        advertise kube-proxy capability;
#                                       enables backend → agent → apiserver
#                                       request tunneling for SaaS topologies
#   KUBEBOLT_AGENT_PPROF_ADDR           opt-in pprof endpoint (e.g.
#                                       127.0.0.1:6060) for live heap profiling
#
# Sprint A added auth/TLS env vars on the agent side too:
#   KUBEBOLT_AGENT_AUTH_MODE            tokenreview | ingest-token
#   KUBEBOLT_AGENT_TOKEN_FILE           /var/run/secrets/kubebolt/token
#   KUBEBOLT_AGENT_TLS_ENABLED          bool
#   KUBEBOLT_AGENT_TLS_CA_FILE          server cert trust bundle
#   KUBEBOLT_AGENT_TLS_CERT_FILE        client cert (mTLS, opt-in)
#   KUBEBOLT_AGENT_TLS_KEY_FILE         client key (mTLS, opt-in)
#   KUBEBOLT_AGENT_TLS_SERVER_NAME      SNI override
