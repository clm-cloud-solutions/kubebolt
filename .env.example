# KubeBolt local development environment variables.
# Copy this file to .env and fill in values to enable optional features.
# The .env file is auto-loaded by `make dev` (and is gitignored).

# ─── AI Copilot ────────────────────────────────────────────────
# The copilot is disabled when KUBEBOLT_AI_API_KEY is empty.
# KubeBolt itself works fully without the copilot.

KUBEBOLT_AI_PROVIDER=anthropic
KUBEBOLT_AI_API_KEY=
KUBEBOLT_AI_MODEL=
KUBEBOLT_AI_BASE_URL=
KUBEBOLT_AI_MAX_TOKENS=4096

# Optional fallback model — used when the primary fails (rate limits, 5xx).
# Can be a different provider or just a cheaper model from the same provider.
KUBEBOLT_AI_FALLBACK_PROVIDER=
KUBEBOLT_AI_FALLBACK_API_KEY=
KUBEBOLT_AI_FALLBACK_MODEL=
KUBEBOLT_AI_FALLBACK_BASE_URL=
