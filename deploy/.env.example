# KubeBolt Docker Compose environment variables.
# Copy to .env and fill in values to enable optional features.
#
# This template mirrors the root .env.example, adapted to Docker Compose:
# service URLs reference compose service names (e.g. http://victoriametrics:8428
# instead of http://localhost:8428) and the agent-side env vars are NOT
# included here — the agent runs as a Kubernetes DaemonSet, not a compose
# service. For the authoritative agent env list see packages/agent/.env.example.
#
# ═══════════════════════════════════════════════════════════════════
#  V2 (2026-05-24) — split into two tiers:
#    [BOOT-TIME]  → must be env (logger, BoltDB path, JWT seed, infra URLs)
#    [Runtime]    → boot fallback; the admin UI's Settings tabs are the
#                   runtime authority. UI overrides win on every read.
#
#  You can leave every [Runtime] var empty and configure end-to-end
#  from the UI after first login. Settings → "Boot snapshot" (button
#  top-right) shows you what env values were captured at startup vs
#  what the UI has stored.
# ═══════════════════════════════════════════════════════════════════

# ─── [BOOT-TIME] Logging ───────────────────────────────────────
# LOG_LEVEL: debug | info (default) | warn | error
# LOG_FORMAT: text (default) | json — use json for structured log ingestion.
# LOG_DIR: when set, tees logs to $DIR/kubebolt.log (appended). Mount a
#          volume at this path to persist logs across container restarts.
# AI_DEBUG (legacy): "1" forces LOG_LEVEL=debug.

KUBEBOLT_LOG_LEVEL=info
KUBEBOLT_LOG_FORMAT=text
KUBEBOLT_LOG_DIR=

# ─── [BOOT-TIME] Auth bootstrap ───────────────────────────────
# JWT secret, admin seeding, recovery escape hatch.
# JWT TTLs (below) are runtime-editable from Settings → Auth but
# require a restart to apply (the JWT service is wired at boot).
# Everything else here is permanent-env.
# Enabled by default. Set KUBEBOLT_AUTH_ENABLED=false for open access (no login).
# If KUBEBOLT_ADMIN_PASSWORD is empty, a random password is generated and
# printed to logs on first start.
# Set KUBEBOLT_JWT_SECRET to persist sessions across container restarts.
# KUBEBOLT_RESET_ADMIN_PASSWORD: set on a restart to reset the admin user's
# password to the given value at next boot, then unset on the following
# restart so the value doesn't persist in the compose file.

KUBEBOLT_AUTH_ENABLED=true
KUBEBOLT_ADMIN_PASSWORD=
KUBEBOLT_JWT_SECRET=
KUBEBOLT_RESET_ADMIN_PASSWORD=

# Where the backend persists its BoltDB (users, tokens, agent registry,
# tenant store). Default /data (a docker volume should be mounted here).
# Can't be UI-editable because we'd have to read settings to know
# where to read settings from.
KUBEBOLT_DATA_DIR=/data

# ═══════════════════════════════════════════════════════════════════
#  TIER 2: RUNTIME-CONFIGURABLE (editable in admin Settings UI)
# ═══════════════════════════════════════════════════════════════════

# ─── [Runtime] Auth TTLs → Settings → Auth ─────────────────────
# Restart required after change (JWT service is wired at boot).
# JWT access token lifetime (Go duration: 15m, 1h, etc.). Default 15m.
# Refresh tokens live in an httpOnly cookie and are tracked server-side.
KUBEBOLT_JWT_EXPIRY=15m
KUBEBOLT_JWT_REFRESH_EXPIRY=720h

# ─── [Runtime] AI Copilot → Settings → AI Copilot ──────────────
# The copilot is disabled when KUBEBOLT_AI_API_KEY is empty.
# KubeBolt itself works fully without the copilot.

KUBEBOLT_AI_PROVIDER=anthropic
KUBEBOLT_AI_API_KEY=
KUBEBOLT_AI_MODEL=
KUBEBOLT_AI_BASE_URL=
KUBEBOLT_AI_MAX_TOKENS=4096

# Optional fallback model — used when the primary fails (rate limits, 5xx).
KUBEBOLT_AI_FALLBACK_PROVIDER=
KUBEBOLT_AI_FALLBACK_API_KEY=
KUBEBOLT_AI_FALLBACK_MODEL=
KUBEBOLT_AI_FALLBACK_BASE_URL=

# Conversation memory management — auto-compaction trims older turns when
# the conversation approaches the configured budget.
# See root .env.example for the full per-knob breakdown.
KUBEBOLT_AI_AUTO_COMPACT=true
KUBEBOLT_AI_SESSION_BUDGET_TOKENS=
KUBEBOLT_AI_AUTO_COMPACT_THRESHOLD=0.80
KUBEBOLT_AI_COMPACT_MODEL=
KUBEBOLT_AI_COMPACT_PRESERVE_TURNS=3

# Kobi conversation history — persisted per user so the operator can refresh /
# re-login and resume. RETENTION_HORIZON drops untouched conversations after a
# Go duration (default 90d); MAX_PER_USER caps the per-user count (default 200).
# See root .env.example for detail.
KUBEBOLT_COPILOT_CONVERSATION_RETENTION_HORIZON=2160h
KUBEBOLT_COPILOT_CONVERSATION_MAX_PER_USER=200

# Render persistent collapsible tool-call cards in the chat panel.
KUBEBOLT_AI_SHOW_TOOL_CALLS=true

# Kobi action governance (Sprint 1). Master switch (false → read-only
# advisory) + destructive-ops sub-switch (false → delete/scale-to-0
# withheld + rejected server-side). Both default true (the action surface
# already shipped; toggles are an opt-out).
KUBEBOLT_AI_ACTIONS_ENABLED=true
KUBEBOLT_AI_DESTRUCTIVE_ACTIONS_ENABLED=true
# How long the UI polls an executed action for convergence before marking it
# "did not converge" and auto-triggering a Kobi root-cause turn (Go duration,
# floored at 10s). Default 90s.
KUBEBOLT_AI_ACTION_PROGRESS_TIMEOUT=90s
# Max tool-call rounds for one Kobi turn. On exhaustion Kobi summarizes what it
# found in a final tools-free turn instead of erroring out. Raise for small,
# sequential models (e.g. Haiku) needing more steps for a deep RCA. Clamped to
# [2, 40]. Default 20.
KUBEBOLT_AI_MAX_ROUNDS=20

# ─── [Runtime] Notifications → Settings → Notifications ───────
# Each channel is enabled by providing its webhook URL.
# Disabled when no URLs are set.
# Insights at or above MIN_SEVERITY trigger notifications; same insight
# within COOLDOWN is only sent once.
# BASE_URL is optional — included as a link back to KubeBolt.

KUBEBOLT_SLACK_WEBHOOK_URL=
KUBEBOLT_DISCORD_WEBHOOK_URL=
KUBEBOLT_NOTIFICATIONS_ENABLED=true
KUBEBOLT_NOTIFICATIONS_MIN_SEVERITY=warning
KUBEBOLT_NOTIFICATIONS_COOLDOWN=1h
KUBEBOLT_NOTIFICATIONS_BASE_URL=
KUBEBOLT_NOTIFICATIONS_INCLUDE_RESOLVED=false

# ─── [Runtime] Email (SMTP) → Settings → Notifications ────────
# Enabled when HOST + FROM + TO are all set.
# Port 587 uses STARTTLS (most providers); port 465 uses implicit TLS.
# TO accepts multiple addresses separated by commas.
# DIGEST_MODE: "instant" (default), "hourly", "daily"

KUBEBOLT_SMTP_HOST=
KUBEBOLT_SMTP_PORT=587
KUBEBOLT_SMTP_USERNAME=
KUBEBOLT_SMTP_PASSWORD=
KUBEBOLT_SMTP_FROM=
KUBEBOLT_SMTP_TO=
KUBEBOLT_SMTP_DIGEST_MODE=instant

# ─── [BOOT-TIME] Metrics storage (VictoriaMetrics) ────────────
# The backend writes received samples to VictoriaMetrics + queries them via
# PromQL. The compose stack ships VM as a service; the URL below is the
# in-compose name. Override to point at an external Prom-compatible TSDB
# (Thanos, Cortex, existing Prometheus, etc.). Editing via UI would
# invalidate in-flight queries against the previous target.
KUBEBOLT_METRICS_STORAGE_URL=http://victoriametrics:8428
KUBEBOLT_METRICS_RETENTION=30d

# ─── [Runtime] Prom remote_write receiver → Settings → Agents & Ingest ──
# Gates POST /api/v1/prom/write — the path vmagent (kubebolt-agent
# sidecar) and external Prom installs use to ship samples into VM.
# Default OFF.
KUBEBOLT_REMOTE_WRITE_ENABLED=false

# Three-tier enforcement for the receiver. Same disabled / permissive /
# enforced semantics as KUBEBOLT_AGENT_AUTH_MODE on the gRPC channel,
# and shares the TenantsStore (vmagent reuses the agent ingest-token
# Secret). See root .env.example for the full mode-by-mode behavior.
KUBEBOLT_REMOTE_WRITE_AUTH_MODE=disabled

# Per-tenant fleet-wide defaults for the rate limiter + cardinality cap.
# Per-tenant overrides via the admin API (PUT /admin/tenants/:id/limits)
# take precedence; this file sets the fallbacks tenants inherit.
KUBEBOLT_PROM_WRITE_DEFAULT_SAMPLES_PER_SEC=10000
KUBEBOLT_PROM_WRITE_DEFAULT_BURST_SAMPLES=100000
KUBEBOLT_PROM_WRITE_DEFAULT_MAX_ACTIVE_SERIES=1000000

# Core/custom series filter (Layer 2 cardinality control). Drop the
# customer's own remote_write'd app metrics that KubeBolt doesn't consume.
# Self-hosted keeps custom (your VM); set ALLOW_CUSTOM_SERIES=false to drop.
KUBEBOLT_PROM_WRITE_NAME_FILTER_ENABLED=true
KUBEBOLT_PROM_WRITE_ALLOW_CUSTOM_SERIES=true

# ─── [Runtime] Agents & Ingest channel → Settings → Agents & Ingest ──
# Spec #09 V2 moves the agent ↔ backend communication plane entirely
# into the admin UI. UI changes don't need a redeploy except for the
# three RESTART-REQUIRED fields (auth mode, token audience, mTLS)
# which are wired into the gRPC interceptor at boot.
# Controls how the backend exposes its gRPC channel to kubebolt-agent
# DaemonSet instances and how it authenticates incoming connections.

# Enforcement matrix for the auth interceptor:
#   disabled    accept every connection (Sprint A migration default).
#   permissive  try to authenticate; on failure log a WARN and accept.
#   enforced    reject any unauthenticated / failed connection.
KUBEBOLT_AGENT_AUTH_MODE=disabled

# External address remote agents dial to reach this backend's gRPC ingest
# (host:port, e.g. agent.kubebolt.io:443). Set on HOSTED / SaaS deployments —
# the "add cluster" wizard uses it as the backendUrl default + SaaS-mode (TLS
# on, auth required, secret created in the operator's OWN cluster). Empty for
# co-located installs (the wizard infers from the Service). Overridable in Settings.
KUBEBOLT_AGENT_INGEST_URL=

# Bind address for the gRPC channel. Default: 0.0.0.0:9090 — published
# by docker-compose on the host's :9090.
KUBEBOLT_AGENT_GRPC_ADDR=

# Audience for tokenreview-mode agent tokens. Must match the agent's
# auth.tokenReview.audience helm value. Default: "kubebolt-backend".
KUBEBOLT_AGENT_TOKEN_AUDIENCE=

# Transport security for the gRPC channel.
KUBEBOLT_AGENT_TLS_CERT_FILE=
KUBEBOLT_AGENT_TLS_KEY_FILE=
KUBEBOLT_AGENT_TLS_CLIENT_CA=
KUBEBOLT_AGENT_REQUIRE_MTLS=false

# Per-tenant token-bucket rate limiter. Off by default.
KUBEBOLT_AGENT_RATE_LIMIT_ENABLED=false
KUBEBOLT_AGENT_RATE_LIMIT_RPS=1000
KUBEBOLT_AGENT_RATE_LIMIT_BURST=2000

# Auto-register clusters surfaced through agent-proxy in the cluster
# selector. Off by default — single-cluster self-hosted setups leave it
# off; multi-cluster fleet operators flip it on so newly deployed agents
# show up automatically.
KUBEBOLT_AGENT_AUTOREGISTER_CLUSTERS=false

# Persistence horizon for the agent registry. Records whose
# DisconnectedAt is older than this duration are pruned hourly.
# Records for currently-connected agents (DisconnectedAt zero) never
# expire. Go duration: 12h, 7d, 24h. Default: 24h.
KUBEBOLT_AGENT_REGISTRY_PRUNE_HORIZON=24h

# Max gRPC message size on the agent channel, both directions (api <-> agent).
# The channel proxies apiserver responses that can exceed gRPC's 4 MiB default on
# large clusters — symptom: "ResourceExhausted: received message larger than max",
# which tears down the whole session (metrics included). Must match the agent's
# value (packages/agent KUBEBOLT_AGENT_MAX_MSG_BYTES). Bytes. Default: 67108864 (64 MiB).
KUBEBOLT_AGENT_MAX_MSG_BYTES=67108864

# Retention horizon for persisted insights (Sprint 0). RESOLVED insight
# records older than this are pruned hourly; ACTIVE insights never expire.
# Controls how far back /insights?history=true can look. Default: 7d (168h).
KUBEBOLT_INSIGHTS_RETENTION_HORIZON=168h

# Retention horizon for the action-audit trail (Sprint 1). Mutation records
# (UI + Kobi-proposed) older than this are pruned hourly; surfaced in the
# admin action-history view. Default: 90d (2160h).
KUBEBOLT_AUDIT_RETENTION_HORIZON=2160h

# Idle timeout for SPDY tunnels opened via agent-proxy (exec,
# portforward, file browser). Closes tunnels with no activity for this
# duration — catches orphaned sessions when the agent crashes
# mid-operation. Set to 0 to disable (tests only). Default: 5m.
KUBEBOLT_AGENT_TUNNEL_IDLE_TIMEOUT=5m

# Agent-proxy resilience timeouts (configurable so you can WIDEN them under heavy agent
# concurrency or TIGHTEN them to fail faster). Go durations. These are the BOOT BASELINE;
# a platform admin can retune them LIVE (no restart) in Settings → Agents & Ingest — that
# override wins at runtime.
# Hard deadline for an agent-proxy cluster connect/cache-sync; a stuck agent fails the
# connect (cluster shown unreachable) instead of hanging. Default: 25s.
KUBEBOLT_AGENT_PROXY_CONNECT_TIMEOUT=25s
# If an agent has in-flight proxied requests but delivers no response for this long, the
# backend force-closes its channel to trigger a fresh reconnect. 0 disables. Default: 45s.
KUBEBOLT_AGENT_PROXY_STUCK_TIMEOUT=45s
# Fallback per-request timeout for non-watch agent-proxy calls when the caller sets none.
# Default: 30s.
KUBEBOLT_AGENT_PROXY_REQUEST_TIMEOUT=30s

# ─── [Runtime] Update check ────────────────────────────────────
# Whether the backend periodically queries GitHub releases to surface
# a "new version available" chip in the UI. Set to false for
# air-gapped installs — no outbound traffic to github.com will
# occur. Cache TTL is 6h backend-side. Admins can toggle at runtime
# via Settings → General. Default: true.
KUBEBOLT_UPDATE_CHECK_ENABLED=true

# Cold cluster-connect informer cache-sync timeout (seconds). Raise for
# large EKS/GKE clusters that flake with "cluster may be unreachable" on
# the first switch. Runtime-overridable via Settings → General (no
# restart). Range 5-600. Default: 45.
KUBEBOLT_CACHE_SYNC_TIMEOUT_SECONDS=45

# ─── kubebolt-agent (DaemonSet env) ───────────────────────────
# Agent env vars live on the Pod spec, NOT in this file. See
# packages/agent/.env.example for the full, authoritative list and
# defaults. Quick reference:
#
#   KUBEBOLT_BACKEND_URL            where the agent ships samples to
#   KUBEBOLT_AGENT_NODE_NAME/_IP    downward-API: spec.nodeName / status.hostIP
#   KUBEBOLT_AGENT_CLUSTER_NAME     human-readable label; cluster_id is
#                                   auto-discovered from the kube-system UID
#   KUBEBOLT_TENANT_ID              per-tenant identifier for SaaS
#                                   ingest (Phase 3 Day 4.2)
#   KUBEBOLT_HUBBLE_ENABLED         flow collector kill-switch (default true)
#   KUBEBOLT_HUBBLE_RELAY_ADDR      override default relay target
#   KUBEBOLT_HUBBLE_RELAY_CA_FILE   enables TLS (add CERT_FILE+KEY_FILE for mTLS)
#   KUBEBOLT_AGENT_DEFER_NODE_NETWORK suppress agent node_network_*
#                                   emission when external Prom scrapes
#                                   node-exporter (deduplication)
#   KUBEBOLT_AGENT_PPROF_ADDR       opt-in pprof endpoint (e.g.
#                                   127.0.0.1:6060) for live heap profiling
#
# Sprint A added auth/TLS env vars on the agent side too:
#   KUBEBOLT_AGENT_AUTH_MODE        tokenreview | ingest-token
#   KUBEBOLT_AGENT_TOKEN_FILE       /var/run/secrets/kubebolt/token
#   KUBEBOLT_AGENT_TLS_ENABLED      bool
#   KUBEBOLT_AGENT_TLS_CA_FILE      server cert trust bundle
#   KUBEBOLT_AGENT_TLS_CERT_FILE    client cert (mTLS, opt-in)
#   KUBEBOLT_AGENT_TLS_KEY_FILE     client key (mTLS, opt-in)
#   KUBEBOLT_AGENT_TLS_SERVER_NAME  SNI override
