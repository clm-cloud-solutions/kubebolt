# KubeBolt Docker Compose environment variables.
# Copy to .env and fill in values to enable optional features.

# Logging
# LOG_LEVEL: debug | info (default) | warn | error
# LOG_FORMAT: text (default) | json — use json for structured log ingestion.
# LOG_DIR: when set, tees logs to $DIR/kubebolt.log (appended). Mount a
#          volume at this path to persist logs across container restarts.
# AI_DEBUG (legacy): "1" forces LOG_LEVEL=debug.

KUBEBOLT_LOG_LEVEL=info
KUBEBOLT_LOG_FORMAT=text
KUBEBOLT_LOG_DIR=

# Authentication — enabled by default.
# Set KUBEBOLT_AUTH_ENABLED=false for open access (no login required).
# If KUBEBOLT_ADMIN_PASSWORD is empty, a random password is generated and printed to logs.
# Set KUBEBOLT_JWT_SECRET to persist sessions across container restarts.

KUBEBOLT_AUTH_ENABLED=true
KUBEBOLT_ADMIN_PASSWORD=
KUBEBOLT_JWT_SECRET=

# AI Copilot — uses your own LLM provider API key.
# Leave KUBEBOLT_AI_API_KEY empty to disable the copilot.
# KubeBolt itself works fully without the copilot.

KUBEBOLT_AI_PROVIDER=anthropic
KUBEBOLT_AI_API_KEY=
KUBEBOLT_AI_MODEL=
KUBEBOLT_AI_BASE_URL=
KUBEBOLT_AI_MAX_TOKENS=4096

# Optional fallback model — used when the primary fails.
# Can be a different provider or just a cheaper model from the same provider.
KUBEBOLT_AI_FALLBACK_PROVIDER=
KUBEBOLT_AI_FALLBACK_API_KEY=
KUBEBOLT_AI_FALLBACK_MODEL=
KUBEBOLT_AI_FALLBACK_BASE_URL=

# Conversation memory management. See root .env.example for full docs.
KUBEBOLT_AI_AUTO_COMPACT=true
KUBEBOLT_AI_SESSION_BUDGET_TOKENS=
KUBEBOLT_AI_AUTO_COMPACT_THRESHOLD=0.80
KUBEBOLT_AI_COMPACT_MODEL=
KUBEBOLT_AI_COMPACT_PRESERVE_TURNS=3

# Render persistent collapsible tool-call cards in the chat panel.
# Default true. Set to false to keep only the final assistant text.
KUBEBOLT_AI_SHOW_TOOL_CALLS=true

# Metrics storage (Phase 2). VictoriaMetrics is the default TSDB; the backend
# writes metrics received from kubebolt-agent via Prom remote_write and
# queries them via PromQL. Point the URL at any Prom-compatible endpoint to
# substitute (e.g. an existing Prometheus, Thanos, or Cortex).
KUBEBOLT_METRICS_STORAGE_URL=http://victoriametrics:8428
KUBEBOLT_METRICS_RETENTION=30d

# Prom remote_write receiver (Phase 2). Gates POST /api/v1/prom/write —
# the path vmagent (sidecar in kubebolt-agent v1.0+) uses to ship
# scraped Prom-compatible metrics into VictoriaMetrics. Default OFF.
KUBEBOLT_REMOTE_WRITE_ENABLED=false

# Three-tier enforcement for the receiver. Same disabled / permissive /
# enforced semantics as KUBEBOLT_AGENT_AUTH_MODE on the gRPC channel,
# and shares the TenantsStore (vmagent reuses the agent ingest-token
# Secret). See root .env.example for the full mode-by-mode behavior.
KUBEBOLT_REMOTE_WRITE_AUTH_MODE=disabled

# Per-tenant Prom remote_write limits (Phase 3). Fleet-wide defaults
# for the rate limiter + cardinality enforcement on
# /api/v1/prom/write. Per-tenant overrides via the admin API
# (PUT /admin/tenants/:id/limits) take precedence; this file sets
# the fallbacks tenants inherit when no override is configured.
#
# SAMPLES_PER_SEC    Sustained samples/sec — 10k is generous for a
#                    typical 50-pod cluster
# BURST_SAMPLES      Token bucket size — covers ~10s of scrape bursts
# MAX_ACTIVE_SERIES  Cardinality cap → HTTP 413 with Retry-After: 3600
KUBEBOLT_PROM_WRITE_DEFAULT_SAMPLES_PER_SEC=10000
KUBEBOLT_PROM_WRITE_DEFAULT_BURST_SAMPLES=100000
KUBEBOLT_PROM_WRITE_DEFAULT_MAX_ACTIVE_SERIES=1000000
